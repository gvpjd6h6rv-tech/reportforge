<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>SAP Crystal Reports for SAP Business One</title>
<style>
@layer reset,tokens,base,xp,chrome,canvas,elements,selection,panels,menus,utils;

@layer reset {
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{overflow:hidden;user-select:none;-webkit-user-select:none;font-family:Tahoma,'MS Sans Serif',sans-serif;font-size:11px}
  input,select,textarea{font-family:inherit;font-size:inherit}
}

@layer tokens {
:root{
  --xp-bg:#ECE9D8;--xp-bg-dark:#D4D0C8;--xp-bg-light:#F5F4EE;
  --xp-border-light:#FFFFFF;--xp-border-dark:#716F64;--xp-border-mid:#ACA899;
  --xp-title-s:#0A246A;--xp-title-e:#3A6EA5;--xp-title-inactive:#7A96DF;
  --xp-sel:#316AC5;--xp-sel-fg:#FFF;
  --xp-btn-h:#C1D2EE;--xp-btn-hb:#316AC5;
  --xp-canvas:#808080;--xp-page:#FFF;
  --xp-ruler:#D4D0C8;
  --sec-rh:#FFFDE7;--sec-ph:#E8F5E9;--sec-det:#FFF;--sec-pf:#E3F2FD;--sec-rf:#FCE4EC;--sec-gh:#F3E5F5;--sec-gf:#FFF3E0;
  --cr-handle:#0066CC;--cr-sel-bdr:#0066CC;--cr-field-bg:#F0F8FF;--cr-field-bdr:#6699CC;
  --cr-text-bg:#FFFFF0;--cr-text-bdr:#CCCC99;
  --grid:rgba(0,0,128,0.12);
  --tbar-h:26px;--ruler-side:24px;--ruler-top:16px;--handle:6px;
  --panel-l:148px;--panel-r:202px;
}}

@layer base {
  html,body{width:100%;height:100%;background:var(--xp-bg)}
  button{cursor:pointer;border:none;background:none;padding:0}
}

@layer xp {
  /* ── Window chrome ── */
  #app{display:flex;flex-direction:column;width:100vw;height:100vh;
    border:2px solid var(--xp-title-e);
    box-shadow:2px 2px 6px rgba(0,0,0,.4)}

  /* Title bar */
  #titlebar{
    height:22px;min-height:22px;flex-shrink:0;
    background:linear-gradient(180deg,#1C52A0 0%,#3A6EA5 60%,#2560A0 100%);
    display:flex;align-items:center;padding:0 4px;
    cursor:default}
  #titlebar-icon{width:16px;height:16px;margin-right:4px;flex-shrink:0;
    background:linear-gradient(135deg,#4A90E2,#1A50A0);border-radius:2px;
    display:flex;align-items:center;justify-content:center;color:#fff;font-size:9px}
  #titlebar-text{flex:1;color:#FFF;font-weight:bold;font-size:11px;
    text-shadow:1px 1px 2px rgba(0,0,0,.5);overflow:hidden;white-space:nowrap}
  #titlebar-controls{display:flex;gap:2px;flex-shrink:0}
  .tb-btn{width:16px;height:14px;border-radius:2px;font-size:9px;color:#FFF;
    display:flex;align-items:center;justify-content:center;cursor:pointer;
    border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.1)}
  .tb-btn:hover{background:rgba(255,255,255,.25)}
  .tb-btn.close:hover{background:#C0392B}

  /* Menu bar */
  #menubar{
    height:20px;min-height:20px;flex-shrink:0;background:var(--xp-bg);
    border-bottom:1px solid var(--xp-border-mid);
    display:flex;align-items:stretch;padding:0 2px}
  .menu-item{
    padding:0 8px;display:flex;align-items:center;cursor:default;
    font-size:11px;white-space:nowrap;position:relative}
  .menu-item:hover,.menu-item.open{background:var(--xp-sel);color:var(--xp-sel-fg)}
  .menu-item span{text-decoration:none}
  .menu-item span[data-u]{text-decoration:underline}

  /* Dropdown menus */
  .dropdown{
    position:fixed;z-index:9000;background:var(--xp-bg);
    border:1px solid var(--xp-border-dark);
    box-shadow:2px 2px 4px rgba(0,0,0,.3);
    min-width:160px;display:none;padding:2px 0}
  .dropdown.visible{display:block}
  .dd-item{
    padding:3px 20px 3px 24px;cursor:default;font-size:11px;
    display:flex;align-items:center;gap:8px;position:relative}
  .dd-item:hover{background:var(--xp-sel);color:var(--xp-sel-fg)}
  .dd-item.disabled{color:#888;pointer-events:none}
  .dd-sep{height:1px;background:var(--xp-border-mid);margin:2px 4px}
  .dd-check{position:absolute;left:6px;font-size:10px}
  .dd-arrow{margin-left:auto;font-size:9px}
  .dd-shortcut{margin-left:auto;color:#666;font-size:10px}
  .dd-item:hover .dd-shortcut{color:rgba(255,255,255,.8)}

  /* Toolbars */
  #toolbars{flex-shrink:0;border-bottom:1px solid var(--xp-border-mid)}
  .toolbar{
    height:var(--tbar-h);display:flex;align-items:center;
    background:var(--xp-bg);padding:0 2px;gap:1px;flex-wrap:nowrap;overflow:hidden}
  .toolbar:not(:last-child){border-bottom:1px solid var(--xp-border-mid)}
  .tb-sep{width:1px;height:18px;background:var(--xp-border-mid);margin:0 3px;flex-shrink:0}
  .tb-icon{
    width:22px;height:22px;border-radius:2px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;font-size:13px;
    border:1px solid transparent;cursor:pointer;position:relative}
  .tb-icon:hover{border-color:var(--xp-btn-hb);background:var(--xp-btn-h)}
  .tb-icon.active{border-color:var(--xp-btn-hb);background:#B8CCE4;
    box-shadow:inset 1px 1px 2px rgba(0,0,0,.15)}
  .tb-icon[title]:hover::after{
    content:attr(title);position:absolute;top:24px;left:0;z-index:8000;
    background:#FFFFCC;border:1px solid #808080;padding:2px 6px;
    font-size:11px;white-space:nowrap;color:#000;pointer-events:none}
  .tb-select{
    height:20px;border:1px inset var(--xp-border-mid);background:var(--xp-bg-light);
    font-size:11px;padding:0 2px;cursor:pointer;flex-shrink:0}

  /* Format toolbar special elements */
  #tb-font-name{width:110px}
  #tb-font-size{width:36px}
  .color-swatch{
    width:16px;height:10px;border:1px solid #333;display:inline-block;
    vertical-align:middle;margin-left:1px}

  /* Tabs */
  #tabs-row{
    height:26px;min-height:26px;flex-shrink:0;
    background:var(--xp-bg-dark);
    border-bottom:1px solid var(--xp-border-mid);
    display:flex;align-items:flex-end;padding:0 4px;gap:2px}
  .file-tab{
    height:23px;padding:0 10px;font-size:11px;cursor:pointer;
    border:1px solid var(--xp-border-mid);border-bottom:none;
    background:var(--xp-bg-dark);border-radius:3px 3px 0 0;
    display:flex;align-items:center;gap:4px}
  .file-tab.active{background:var(--xp-bg);border-bottom:1px solid var(--xp-bg);margin-bottom:-1px;z-index:1}
  .file-tab .close-tab{font-size:9px;opacity:.6;margin-left:4px}
  .file-tab .close-tab:hover{opacity:1;color:red}
  .sub-tabs{display:flex;align-items:center;margin-left:auto;gap:2px}
  .sub-tab{
    height:19px;padding:0 10px;font-size:11px;cursor:pointer;
    border:1px solid var(--xp-border-mid);border-bottom:none;
    background:var(--xp-bg-dark);border-radius:2px 2px 0 0;
    display:flex;align-items:center}
  .sub-tab.active{background:var(--xp-bg);border-bottom:1px solid var(--xp-bg);margin-bottom:-1px;
    font-weight:bold;color:var(--xp-sel)}

  /* Status bar */
  #statusbar{
    height:20px;min-height:20px;flex-shrink:0;background:var(--xp-bg);
    border-top:1px solid var(--xp-border-mid);
    display:flex;align-items:center;font-size:11px}
  .sb-cell{
    padding:0 8px;border-right:1px solid var(--xp-border-mid);
    height:100%;display:flex;align-items:center;white-space:nowrap}
  .sb-cell.grow{flex:1}

  /* ── Main layout ── */
  #main-area{
    flex:1;display:flex;overflow:hidden;background:var(--xp-bg-dark);
    border-top:1px solid var(--xp-border-mid)}

  /* Left panel */
  #panel-left{
    width:var(--panel-l);min-width:var(--panel-l);
    background:var(--xp-bg);border-right:1px solid var(--xp-border-mid);
    display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
  .panel-title{
    height:18px;background:linear-gradient(180deg,#3A6EA5,#2255A0);
    color:#FFF;font-size:10px;font-weight:bold;
    padding:0 6px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
  .panel-mini-btn{
    width:13px;height:12px;background:rgba(255,255,255,.15);
    border:1px solid rgba(255,255,255,.3);border-radius:1px;
    font-size:8px;color:#FFF;display:flex;align-items:center;justify-content:center;cursor:pointer}
  .panel-mini-btn:hover{background:rgba(255,255,255,.3)}
  .panel-section-list{
    flex:1;overflow-y:auto;font-size:11px}
  .panel-section-item{
    padding:2px 6px;cursor:default;border-bottom:1px solid var(--xp-bg-dark);
    display:flex;align-items:center;justify-content:space-between}
  .panel-section-item:hover{background:var(--xp-btn-h)}
  .panel-section-item.selected{background:var(--xp-sel);color:#FFF}
  .panel-section-h{font-size:10px;color:#888;padding:2px 6px;background:var(--xp-bg-dark)}
  .panel-tabs{
    height:22px;display:flex;border-top:1px solid var(--xp-border-mid);flex-shrink:0}
  .panel-tab{
    flex:1;font-size:10px;background:var(--xp-bg-dark);border-right:1px solid var(--xp-border-mid);
    display:flex;align-items:center;justify-content:center;cursor:pointer}
  .panel-tab.active{background:var(--xp-bg);font-weight:bold}

  /* Right panel */
  #panel-right{
    width:var(--panel-r);min-width:var(--panel-r);
    background:var(--xp-bg);border-left:1px solid var(--xp-border-mid);
    display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
  #field-explorer{flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0}
  #field-tree{flex:1;overflow-y:auto;font-size:11px;padding:2px 0}
  .tree-node{padding:1px 0;cursor:default}
  .tree-node-label{
    display:flex;align-items:center;gap:3px;padding:2px 4px;
    white-space:nowrap;overflow:hidden}
  .tree-node-label:hover{background:var(--xp-btn-h)}
  .tree-node-label.selected{background:var(--xp-sel);color:#FFF}
  .tree-arrow{font-size:9px;width:10px;text-align:center;flex-shrink:0;color:#444}
  .tree-icon{font-size:11px;flex-shrink:0}
  .tree-text{overflow:hidden;text-overflow:ellipsis;flex:1}
  .tree-children{padding-left:14px;display:none}
  .tree-children.open{display:block}
  .tree-field{
    display:flex;align-items:center;gap:3px;padding:2px 4px;
    cursor:grab;font-size:10px;color:#003;}
  .tree-field:hover{background:var(--xp-btn-h)}
  .tree-field.dragging{opacity:.5}
  .tree-field-type{
    font-size:9px;color:#666;margin-left:auto;flex-shrink:0}

  /* Properties panel */
  #properties-panel{
    border-top:1px solid var(--xp-border-mid);
    display:flex;flex-direction:column;overflow:hidden}
  #properties-panel.collapsed #props-body{display:none}
  #props-title{
    height:18px;background:linear-gradient(180deg,#2A5EA0,#1A4A80);
    color:#FFF;font-size:10px;font-weight:bold;
    padding:0 6px;display:flex;align-items:center;justify-content:space-between;
    cursor:pointer;flex-shrink:0}
  #props-body{
    overflow-y:auto;padding:4px;font-size:10px;
    max-height:260px;min-height:100px}
  .prop-row{
    display:flex;align-items:center;margin-bottom:3px;gap:4px}
  .prop-label{
    width:52px;flex-shrink:0;color:#333;text-align:right;font-size:10px}
  .prop-input{
    flex:1;height:17px;border:1px inset var(--xp-border-mid);
    background:var(--xp-bg-light);padding:0 2px;font-size:10px;min-width:0}
  .prop-select{
    flex:1;height:17px;border:1px inset var(--xp-border-mid);
    background:var(--xp-bg-light);font-size:10px}
  .prop-row-2{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-bottom:3px}
  .prop-row-4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:2px;margin-bottom:3px}
  .prop-num{
    height:17px;border:1px inset var(--xp-border-mid);
    background:var(--xp-bg-light);padding:0 2px;font-size:10px;
    width:100%;text-align:right}
  .prop-section{font-size:10px;color:#555;border-bottom:1px solid var(--xp-border-mid);
    padding:2px 0;margin:3px 0;font-weight:bold}
  .prop-color-row{display:flex;align-items:center;gap:4px;margin-bottom:3px}
  .prop-color-swatch{
    width:24px;height:16px;border:1px solid #333;cursor:pointer;flex-shrink:0}
  .prop-check-row{display:flex;gap:8px;margin-bottom:3px;align-items:center}
  .prop-check-label{display:flex;align-items:center;gap:3px;cursor:pointer;font-size:10px}
  #props-empty{padding:8px;color:#888;font-size:10px;text-align:center}
}

@layer canvas {
  /* ── Center canvas area ── */
  #canvas-area{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
  #ruler-h-row{
    height:var(--ruler-top);display:flex;flex-shrink:0;
    background:var(--xp-ruler);border-bottom:1px solid var(--xp-border-mid)}
  #ruler-corner{
    width:calc(var(--ruler-side) + 1px);height:100%;flex-shrink:0;
    border-right:1px solid var(--xp-border-mid);background:var(--xp-ruler)}
  #ruler-h-canvas{
    flex:1;overflow:hidden;position:relative;
    background:var(--xp-ruler)}
  #ruler-h-inner{
    position:absolute;top:0;left:0;height:100%;
    pointer-events:none;white-space:nowrap}

  #canvas-row{flex:1;display:flex;overflow:hidden;min-height:0}
  #ruler-v{
    width:var(--ruler-side);flex-shrink:0;overflow:hidden;
    background:var(--xp-ruler);border-right:1px solid var(--xp-border-mid);
    position:relative}
  #ruler-v-inner{position:absolute;top:0;left:0;width:100%;pointer-events:none}

  #canvas-scroll{
    flex:1;overflow:auto;background:var(--xp-canvas);position:relative}
  #canvas-scroll.tool-pointer{cursor:default}
  #canvas-scroll.tool-text{cursor:crosshair}
  #canvas-scroll.tool-field{cursor:crosshair}
  #canvas-scroll.tool-line{cursor:crosshair}
  #canvas-scroll.tool-box{cursor:crosshair}

  #canvas-inner{
    position:relative;margin:16px auto;
    background:var(--xp-page);
    box-shadow:3px 3px 10px rgba(0,0,0,.4);
    transform-origin:top center}

  /* Grid overlay */
  #grid-overlay{
    position:absolute;inset:0;pointer-events:none;z-index:1;
    background-image:radial-gradient(circle,var(--grid) 1px,transparent 1px);
    background-size:4px 4px}
  #grid-overlay.hidden{display:none}

  /* Section bands */
  .cr-section{
    position:relative;width:100%;overflow:visible;z-index:2;
    border-bottom:2px solid var(--xp-border-mid)}
  .cr-section[data-stype="rh"]{background:var(--sec-rh)}
  .cr-section[data-stype="ph"]{background:var(--sec-ph)}
  .cr-section[data-stype="det"]{background:var(--sec-det)}
  .cr-section[data-stype="pf"]{background:var(--sec-pf)}
  .cr-section[data-stype="rf"]{background:var(--sec-rf)}
  .cr-section[data-stype="gh"]{background:var(--sec-gh)}
  .cr-section[data-stype="gf"]{background:var(--sec-gf)}
  .section-resize-handle{
    position:absolute;bottom:-3px;left:0;right:0;height:6px;
    cursor:ns-resize;z-index:50;
    background:transparent}
  .section-resize-handle:hover,.section-resize-handle.dragging{
    background:rgba(0,102,204,.25);
    border-bottom:2px solid var(--cr-handle)}
  .section-label{
    position:absolute;right:0;top:0;bottom:0;width:22px;
    border-left:1px solid var(--xp-border-mid);
    display:flex;align-items:center;justify-content:center;
    font-size:9px;color:#555;background:rgba(0,0,0,.04);z-index:10;
    cursor:default;writing-mode:vertical-lr;text-orientation:mixed;
    padding:2px}
  .section-resize-badge{
    position:fixed;background:#333;color:#FFF;font-size:9px;
    padding:2px 5px;border-radius:2px;pointer-events:none;z-index:9999;
    display:none}

  /* Ruler marks */
  .ruler-mark{
    position:absolute;top:0;height:100%;
    display:flex;flex-direction:column;justify-content:flex-end;
    pointer-events:none}
  .ruler-mark-major{width:1px;background:var(--xp-border-dark)}
  .ruler-num{
    font-size:7px;color:#333;position:absolute;top:1px;
    transform:translateX(-50%);white-space:nowrap}
  .ruler-cursor{
    position:absolute;top:0;width:1px;height:100%;
    background:rgba(0,102,204,.6);pointer-events:none;z-index:5}
}

@layer elements {
  /* ── Design elements ── */
  .cr-element{
    position:absolute;cursor:move;z-index:20;
    box-sizing:border-box;overflow:hidden}
  .cr-element:hover:not(.selected){
    outline:1px dashed rgba(0,102,204,.5)}

  /* Field element */
  .cr-element[data-type="field"]{
    background:var(--cr-field-bg);border:1px solid var(--cr-field-bdr);
    display:flex;align-items:center;padding:0 2px;white-space:nowrap;overflow:hidden}
  .cr-element[data-type="field"] .el-content{
    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    color:#003;font-size:7.5px;font-family:Tahoma,sans-serif;
    flex:1;min-width:0;pointer-events:none}
  .el-field-icon{font-size:8px;flex-shrink:0;margin-right:2px;pointer-events:none}

  /* Text element */
  .cr-element[data-type="text"]{
    background:var(--cr-text-bg);border:1px solid var(--cr-text-bdr);
    display:flex;align-items:center;padding:0 2px;overflow:hidden}
  .cr-element[data-type="text"] .el-content{
    overflow:hidden;white-space:pre;flex:1;min-width:0;
    outline:none;pointer-events:none}
  .cr-element[data-type="text"].editing .el-content{
    pointer-events:all;cursor:text;caret-color:#000}
  .cr-element[data-type="text"].editing{cursor:text;outline:2px solid var(--xp-sel)}

  /* Line element */
  .cr-element[data-type="line"]{background:transparent;border:none;overflow:visible}
  .cr-element[data-type="line"] .el-content{pointer-events:none;display:block}

  /* Box element */
  .cr-element[data-type="rect"]{overflow:visible}
  .cr-element[data-type="rect"] .el-content{
    width:100%;height:100%;display:block;pointer-events:none}

  /* Image element */
  .cr-element[data-type="image"]{
    border:1px dashed #999;
    display:flex;align-items:center;justify-content:center;background:#F9F9F9}
  .cr-element[data-type="image"] .el-content{
    font-size:9px;color:#999;pointer-events:none}

  /* Selected state */
  .cr-element.selected{
    outline:1px solid var(--cr-sel-bdr) !important;
    z-index:30}

  /* Selection handles overlay */
  #handles-layer{
    position:absolute;inset:0;pointer-events:none;z-index:40;overflow:visible}
  .sel-handle{
    position:absolute;width:var(--handle);height:var(--handle);
    background:var(--cr-handle-bg);border:1px solid var(--cr-handle);
    pointer-events:all;cursor:nwse-resize;z-index:41;
    transform:translate(-50%,-50%)}
  .sel-handle[data-pos="n"]{cursor:ns-resize}
  .sel-handle[data-pos="s"]{cursor:ns-resize}
  .sel-handle[data-pos="e"]{cursor:ew-resize}
  .sel-handle[data-pos="w"]{cursor:ew-resize}
  .sel-handle[data-pos="nw"]{cursor:nw-resize}
  .sel-handle[data-pos="ne"]{cursor:ne-resize}
  .sel-handle[data-pos="sw"]{cursor:sw-resize}
  .sel-handle[data-pos="se"]{cursor:se-resize}

  /* Rubber band selection */
  #rubber-band{
    position:absolute;border:1px dashed var(--cr-sel-bdr);
    background:rgba(0,102,204,.08);pointer-events:none;z-index:45;display:none}

  /* Insert ghost */
  #insert-ghost{
    position:absolute;border:1px dashed #0060C0;
    background:rgba(0,96,192,.1);pointer-events:none;z-index:45;display:none}

  /* Field drag ghost */
  #field-drag-ghost{
    position:fixed;z-index:9999;background:#F0F8FF;
    border:1px solid var(--cr-field-bdr);padding:2px 6px;
    font-size:10px;pointer-events:none;display:none;
    box-shadow:2px 2px 4px rgba(0,0,0,.3);color:#003}
  #field-drop-indicator{
    position:absolute;pointer-events:none;z-index:44;
    border:2px dashed #0066CC;background:rgba(0,102,204,.08);
    display:none}
}

@layer selection {
  /* Multi-select count badge */
  #selection-info{
    position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
    background:rgba(50,50,50,.85);color:#FFF;font-size:10px;
    padding:3px 10px;border-radius:3px;pointer-events:none;
    z-index:8000;display:none}
}

@layer panels {
  /* Preview mode overlay */
  #preview-layer{
    position:absolute;inset:0;z-index:100;background:#FFF;
    overflow:auto;display:none;padding:16px}
  #preview-layer.visible{display:block}
  #preview-content{max-width:794px;margin:0 auto;font-family:Arial,sans-serif;font-size:8pt;color:#000}
}

@layer menus {
  /* Context menu */
  #ctx-menu{
    position:fixed;z-index:9500;background:var(--xp-bg);
    border:1px solid var(--xp-border-dark);
    box-shadow:2px 2px 5px rgba(0,0,0,.35);
    min-width:170px;display:none;padding:2px 0}
  #ctx-menu.visible{display:block}
  .ctx-item{
    padding:3px 24px 3px 20px;cursor:default;font-size:11px;
    display:flex;align-items:center;justify-content:space-between}
  .ctx-item:hover{background:var(--xp-sel);color:#FFF}
  .ctx-item.disabled{color:#888;pointer-events:none}
  .ctx-item.separator{height:1px;background:var(--xp-border-mid);margin:2px 4px;padding:0}
  .ctx-icon{width:14px;height:14px;margin-right:4px;flex-shrink:0;
    font-size:11px;display:flex;align-items:center}
  .ctx-shortcut{font-size:10px;color:#666;margin-left:auto}
  .ctx-item:hover .ctx-shortcut{color:rgba(255,255,255,.8)}

  /* Format dialog */
  #format-dialog{
    position:fixed;z-index:9600;background:var(--xp-bg);
    border:2px solid var(--xp-title-e);
    box-shadow:4px 4px 12px rgba(0,0,0,.5);
    min-width:320px;display:none}
  #format-dialog.visible{display:block}
  .dialog-title{
    height:20px;background:linear-gradient(180deg,var(--xp-title-s),var(--xp-title-e));
    color:#FFF;font-size:11px;font-weight:bold;
    padding:0 8px;display:flex;align-items:center;justify-content:space-between;cursor:move}
  .dialog-body{padding:12px}
  .dialog-footer{
    padding:8px;border-top:1px solid var(--xp-border-mid);
    display:flex;justify-content:flex-end;gap:6px}
  .xp-btn{
    min-width:70px;height:22px;padding:0 10px;
    background:linear-gradient(180deg,#F5F4EE,#D4D0C8);
    border:1px solid var(--xp-border-dark);
    border-right-color:var(--xp-border-light) !important;
    border-bottom-color:var(--xp-border-light) !important;
    font-size:11px;cursor:pointer}
  .xp-btn:hover{background:linear-gradient(180deg,var(--xp-btn-h),#B8CCE4)}
  .xp-btn:active{
    background:linear-gradient(180deg,#D4D0C8,#F5F4EE);
    border-color:var(--xp-border-light);
    border-right-color:var(--xp-border-dark) !important;
    border-bottom-color:var(--xp-border-dark) !important}
  .xp-btn.primary{background:linear-gradient(180deg,#4A80C8,var(--xp-sel));color:#FFF;border-color:#1A4A90}
}

@layer utils {
  .hidden{display:none!important}
  .no-select{user-select:none;-webkit-user-select:none}
  .monospace{font-family:var(--font-mono)!important}
}

/* ── Multi-doc type selector ── */
#doc-type-bar{
  height:28px;min-height:28px;flex-shrink:0;
  background:var(--xp-bg-dark);border-bottom:2px solid var(--xp-border-mid);
  display:flex;align-items:center;padding:0 6px;gap:4px;overflow-x:auto}
.doc-type-btn{
  height:22px;padding:0 10px;border-radius:3px 3px 0 0;
  font-size:11px;cursor:pointer;border:1px solid var(--xp-border-mid);
  background:var(--xp-bg);display:flex;align-items:center;gap:5px;
  white-space:nowrap;flex-shrink:0;transition:background .1s}
.doc-type-btn:hover{background:var(--xp-btn-h)}
.doc-type-btn.active{font-weight:bold;border-bottom:2px solid currentColor;margin-bottom:-2px;background:#fff}
.doc-type-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
/* Properties panel color accent per doc type */
#props-title{transition:background .2s}

</style>
</head>
<body>
<div id="app">

<!-- ── Title bar ── -->
<div id="titlebar">
  <div id="titlebar-icon">◈</div>
  <div id="titlebar-text">SAP Crystal Reports for SAP Business One - [Factura Electrónica 002-101-000020482]</div>
  <div id="titlebar-controls">
    <div class="tb-btn">─</div>
    <div class="tb-btn">□</div>
    <div class="tb-btn close">✕</div>
  </div>
</div>

<!-- ── Menu bar ── -->
<div id="menubar">
  <div class="menu-item" data-menu="archivo"><span data-u>A</span>rchivo</div>
  <div class="menu-item" data-menu="edicion"><span data-u>E</span>dición</div>
  <div class="menu-item" data-menu="vista"><span data-u>V</span>ista</div>
  <div class="menu-item" data-menu="insertar"><span data-u>I</span>nsertar</div>
  <div class="menu-item" data-menu="formato"><span data-u>F</span>ormato</div>
  <div class="menu-item" data-menu="informe"><span data-u>I</span>nforme</div>
  <div class="menu-item" data-menu="ventana">Ve<span data-u>n</span>tana</div>
  <div class="menu-item" data-menu="ayuda">Ay<span data-u>u</span>da</div>
</div>

<!-- Dropdown menus (hidden by default) -->
<div class="dropdown" id="dd-archivo">
  <div class="dd-item" data-action="new">📄 <span>Nuevo</span><span class="dd-shortcut">Ctrl+N</span></div>
  <div class="dd-item" data-action="open">📂 <span>Abrir...</span><span class="dd-shortcut">Ctrl+O</span></div>
  <div class="dd-item" data-action="save">💾 <span>Guardar</span><span class="dd-shortcut">Ctrl+S</span></div>
  <div class="dd-item" data-action="save-as">💾 <span>Guardar como...</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="export-pdf">📤 <span>Exportar a PDF...</span></div>
  <div class="dd-item" data-action="export-json">📤 <span>Exportar diseño (.rfd.json)</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="print">🖨 <span>Imprimir...</span><span class="dd-shortcut">Ctrl+P</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="quit">🚪 <span>Salir</span><span class="dd-shortcut">Alt+F4</span></div>
</div>
<div class="dropdown" id="dd-edicion">
  <div class="dd-item" data-action="undo">↩ <span>Deshacer</span><span class="dd-shortcut">Ctrl+Z</span></div>
  <div class="dd-item" data-action="redo">↪ <span>Rehacer</span><span class="dd-shortcut">Ctrl+Y</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="cut">✂ <span>Cortar</span><span class="dd-shortcut">Ctrl+X</span></div>
  <div class="dd-item" data-action="copy">📋 <span>Copiar</span><span class="dd-shortcut">Ctrl+C</span></div>
  <div class="dd-item" data-action="paste">📌 <span>Pegar</span><span class="dd-shortcut">Ctrl+V</span></div>
  <div class="dd-item" data-action="delete">🗑 <span>Eliminar</span><span class="dd-shortcut">Del</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="select-all">☑ <span>Seleccionar todo</span><span class="dd-shortcut">Ctrl+A</span></div>
</div>
<div class="dropdown" id="dd-vista">
  <div class="dd-item" data-action="toggle-grid">⊞ <span id="mi-grid">Mostrar cuadrícula</span><span class="dd-shortcut">Ctrl+G</span></div>
  <div class="dd-item" data-action="toggle-snap">🧲 <span id="mi-snap">Ajustar a cuadrícula ✓</span></div>
  <div class="dd-item" data-action="toggle-rulers">📏 <span>Mostrar reglas ✓</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="zoom-in">🔍 <span>Acercar</span><span class="dd-shortcut">+</span></div>
  <div class="dd-item" data-action="zoom-out">🔎 <span>Alejar</span><span class="dd-shortcut">-</span></div>
  <div class="dd-item" data-action="zoom-100">1:1 <span>100%</span><span class="dd-shortcut">Ctrl+1</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="preview">👁 <span>Vista previa</span><span class="dd-shortcut">F5</span></div>
</div>
<div class="dropdown" id="dd-insertar">
  <div class="dd-item" data-action="insert-text">T <span>Objeto de texto</span></div>
  <div class="dd-item" data-action="insert-field">⬚ <span>Campo de base de datos...</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="insert-line">─ <span>Línea</span></div>
  <div class="dd-item" data-action="insert-box">▭ <span>Rectángulo</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="insert-section">+ <span>Sección...</span></div>
</div>
<div class="dropdown" id="dd-formato">
  <div class="dd-item" data-action="format-field">⚙ <span>Formatear campo...</span><span class="dd-shortcut">Alt+Enter</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="align-left">⬱ <span>Alinear a la izquierda</span></div>
  <div class="dd-item" data-action="align-center">≡ <span>Centrar</span></div>
  <div class="dd-item" data-action="align-right">⬰ <span>Alinear a la derecha</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="align-tops">⬆ <span>Alinear bordes superiores</span></div>
  <div class="dd-item" data-action="align-middles">⬕ <span>Alinear centros verticales</span></div>
  <div class="dd-item" data-action="align-bottoms">⬇ <span>Alinear bordes inferiores</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="same-width">↔ <span>Mismo ancho</span></div>
  <div class="dd-item" data-action="same-height">↕ <span>Misma altura</span></div>
  <div class="dd-sep"></div>
  <div class="dd-item" data-action="bring-front">🔼 <span>Traer al frente</span></div>
  <div class="dd-item" data-action="send-back">🔽 <span>Enviar al fondo</span></div>
</div>

<!-- ── Toolbars ── -->
<div id="toolbars">
  <!-- Toolbar 1: File + Edit -->
  <div class="toolbar" id="tb1">
    <button class="tb-icon" title="Nuevo (Ctrl+N)" data-action="new">📄</button>
    <button class="tb-icon" title="Abrir (Ctrl+O)" data-action="open">📂</button>
    <button class="tb-icon" title="Guardar (Ctrl+S)" data-action="save">💾</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Deshacer (Ctrl+Z)" data-action="undo" id="btn-undo">↩</button>
    <button class="tb-icon" title="Rehacer (Ctrl+Y)" data-action="redo" id="btn-redo">↪</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Cortar (Ctrl+X)" data-action="cut">✂</button>
    <button class="tb-icon" title="Copiar (Ctrl+C)" data-action="copy">📋</button>
    <button class="tb-icon" title="Pegar (Ctrl+V)" data-action="paste">📌</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Vista previa (F5)" data-action="preview">👁</button>
    <button class="tb-icon" title="Exportar PDF" data-action="export-pdf">📤</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Actualizar datos (F9)" data-action="refresh">🔄</button>
    <div class="tb-sep"></div>
    <!-- Zoom -->
    <button class="tb-icon" title="Alejar" data-action="zoom-out">🔎</button>
    <select class="tb-select" id="tb-zoom" style="width:54px">
      <option>25%</option><option>50%</option><option>75%</option>
      <option selected>100%</option><option>125%</option>
      <option>150%</option><option>200%</option><option>400%</option>
    </select>
    <button class="tb-icon" title="Acercar" data-action="zoom-in">🔍</button>
    <div class="tb-sep"></div>
    <!-- Navigation -->
    <button class="tb-icon" title="Primera página" data-action="page-first">⏮</button>
    <button class="tb-icon" title="Página anterior" data-action="page-prev">◀</button>
    <span style="font-size:10px;padding:0 4px;white-space:nowrap">Página <input id="tb-page" type="text" value="1" style="width:24px;text-align:center;height:16px;border:1px inset #999;font-size:10px"> de <span id="tb-pages">1</span></span>
    <button class="tb-icon" title="Página siguiente" data-action="page-next">▶</button>
    <button class="tb-icon" title="Última página" data-action="page-last">⏭</button>
  </div>

  <!-- Toolbar 2: Insert tools + Format -->
  <div class="toolbar" id="tb2">
    <!-- Tool selection -->
    <button class="tb-icon active" title="Puntero (Esc)" data-tool="pointer" id="tool-pointer">🖱</button>
    <button class="tb-icon" title="Insertar texto (T)" data-tool="text" id="tool-text">T</button>
    <button class="tb-icon" title="Insertar campo (F)" data-tool="field" id="tool-field" style="font-size:10px;font-weight:bold">⬚</button>
    <button class="tb-icon" title="Insertar línea (L)" data-tool="line" id="tool-line">─</button>
    <button class="tb-icon" title="Insertar rectángulo (B)" data-tool="box" id="tool-box">▭</button>
    <div class="tb-sep"></div>
    <!-- Font -->
    <select class="tb-select" id="tb-font-name" title="Fuente">
      <option>Arial</option><option>Tahoma</option><option selected>Arial</option>
      <option>Courier New</option><option>Times New Roman</option>
      <option>Calibri</option><option>Verdana</option>
    </select>
    <select class="tb-select" id="tb-font-size" style="width:40px" title="Tamaño">
      <option>6</option><option>7</option><option selected>8</option>
      <option>9</option><option>10</option><option>11</option><option>12</option>
      <option>14</option><option>16</option><option>18</option><option>20</option>
    </select>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Negrita (Ctrl+B)" data-format="bold" id="btn-bold" style="font-weight:bold">B</button>
    <button class="tb-icon" title="Cursiva (Ctrl+I)" data-format="italic" id="btn-italic" style="font-style:italic">I</button>
    <button class="tb-icon" title="Subrayado (Ctrl+U)" data-format="underline" id="btn-underline" style="text-decoration:underline">U</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Alinear izquierda" data-format="align-left" id="btn-al">⬱</button>
    <button class="tb-icon" title="Centrar" data-format="align-center" id="btn-ac">≡</button>
    <button class="tb-icon" title="Alinear derecha" data-format="align-right" id="btn-ar">⬰</button>
    <div class="tb-sep"></div>
    <!-- Color buttons -->
    <button class="tb-icon" title="Color de fuente" data-action="color-font" style="font-size:10px">
      A<div class="color-swatch" id="swatch-font" style="background:#000"></div>
    </button>
    <button class="tb-icon" title="Color de fondo" data-action="color-bg" style="font-size:10px">
      🎨<div class="color-swatch" id="swatch-bg" style="background:transparent;border-style:dashed"></div>
    </button>
    <button class="tb-icon" title="Color de borde" data-action="color-border" style="font-size:10px">
      ▭<div class="color-swatch" id="swatch-border" style="background:transparent;border-style:dashed"></div>
    </button>
    <div class="tb-sep"></div>
    <!-- Alignment tools (multi-select) -->
    <button class="tb-icon" title="Alinear bordes izquierdos" data-action="align-lefts">⬜◧</button>
    <button class="tb-icon" title="Alinear centros horizontales" data-action="align-centers">⬜◈</button>
    <button class="tb-icon" title="Alinear bordes derechos" data-action="align-rights">⬜◨</button>
    <button class="tb-icon" title="Alinear bordes superiores" data-action="align-tops">⬜⬆</button>
    <button class="tb-icon" title="Alinear bordes inferiores" data-action="align-bottoms">⬜⬇</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Mismo ancho" data-action="same-width">↔</button>
    <button class="tb-icon" title="Misma altura" data-action="same-height">↕</button>
    <div class="tb-sep"></div>
    <button class="tb-icon" title="Traer al frente" data-action="bring-front">🔼</button>
    <button class="tb-icon" title="Enviar al fondo" data-action="send-back">🔽</button>
    <div class="tb-sep"></div>
    <!-- Grid toggle -->
    <button class="tb-icon active" title="Mostrar cuadrícula (Ctrl+G)" data-action="toggle-grid" id="btn-grid">⊞</button>
    <button class="tb-icon active" title="Ajustar a cuadrícula" data-action="toggle-snap" id="btn-snap">🧲</button>
  </div>
</div>

<!-- ── Tabs ── -->
<div id="tabs-row">
  <div class="file-tab">Página de inicio</div>
  <div class="file-tab active">
    Factura 002-101-000020482
    <span class="close-tab">✕</span>
  </div>
  <div class="sub-tabs">
    <div class="sub-tab active" data-view="design" id="tab-design">Diseño</div>
    <div class="sub-tab" data-view="preview" id="tab-preview">Vista previa</div>
  </div>
</div>


<!-- ── Doc type selector bar ── -->
<div id="doc-type-bar">
  <span style="font-size:10px;color:#666;flex-shrink:0">Tipo de documento:</span>
  <button class="doc-type-btn active" data-doctype="factura"     style="color:#C0511A"><span class="doc-type-dot" style="background:#C0511A"></span>Factura</button>
  <button class="doc-type-btn"        data-doctype="remision"    style="color:#1565C0"><span class="doc-type-dot" style="background:#1565C0"></span>Guía de Remisión</button>
  <button class="doc-type-btn"        data-doctype="nota_credito"style="color:#C62828"><span class="doc-type-dot" style="background:#C62828"></span>Nota de Crédito</button>
  <button class="doc-type-btn"        data-doctype="retencion"   style="color:#4A148C"><span class="doc-type-dot" style="background:#4A148C"></span>Retención</button>
  <button class="doc-type-btn"        data-doctype="liquidacion" style="color:#2E7D32"><span class="doc-type-dot" style="background:#2E7D32"></span>Liquidación de Compras</button>
</div>
<!-- ── Main area ── -->
<div id="main-area">

  <!-- Left panel -->
  <div id="panel-left">
    <div class="panel-title">
      Parámetros
      <div style="display:flex;gap:2px">
        <div class="panel-mini-btn" title="Nuevo parámetro">+</div>
        <div class="panel-mini-btn" title="Editar">✎</div>
        <div class="panel-mini-btn" title="Eliminar">×</div>
        <div class="panel-mini-btn" title="Actualizar">↻</div>
      </div>
    </div>
    <div id="params-list" style="max-height:80px;overflow-y:auto;flex-shrink:0">
      <div class="panel-section-item">▷ EI</div>
      <div class="panel-section-item">▷ EP</div>
    </div>
    <div class="panel-section-h">Secciones del reporte</div>
    <div class="panel-section-list" id="sections-list"></div>
    <div class="panel-tabs">
      <div class="panel-tab active" id="ptab-groups">Grupos</div>
      <div class="panel-tab" id="ptab-params">Parámetros</div>
      <div class="panel-tab" id="ptab-find">Buscar</div>
    </div>
  </div>

  <!-- Center canvas -->
  <div id="canvas-area">
    <div id="ruler-h-row">
      <div id="ruler-corner"></div>
      <div id="ruler-h-canvas">
        <canvas id="ruler-h-inner" height="16"></canvas>
      </div>
    </div>
    <div id="canvas-row">
      <div id="ruler-v">
        <canvas id="ruler-v-inner" width="24"></canvas>
      </div>
      <div id="canvas-scroll">
        <div id="canvas-inner">
          <div id="grid-overlay"></div>
          <div id="sections-container"></div>
          <div id="handles-layer"></div>
          <div id="rubber-band"></div>
          <div id="insert-ghost"></div>
          <div id="field-drop-indicator"></div>
        </div>
        <div id="preview-layer">
          <div id="preview-content"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right panel -->
  <div id="panel-right">
    <div id="field-explorer">
      <div class="panel-title">
        Explorador de campos
        <div style="display:flex;gap:2px">
          <div class="panel-mini-btn" title="Actualizar">↻</div>
          <div class="panel-mini-btn" title="Nuevo">+</div>
          <div class="panel-mini-btn" title="Editar">✎</div>
          <div class="panel-mini-btn" title="Eliminar">×</div>
          <div class="panel-mini-btn" title="Subir">▲</div>
          <div class="panel-mini-btn" title="Bajar">▼</div>
        </div>
      </div>
      <div id="field-tree"></div>
    </div>
    <div id="properties-panel">
      <div id="props-title">▼ Propiedades del elemento</div>
      <div id="props-body">
        <div id="props-empty">Seleccione un elemento para ver sus propiedades</div>
        <div id="props-form" class="hidden"></div>
      </div>
    </div>
  </div>

</div><!-- /main-area -->

<!-- ── Status bar ── -->
<div id="statusbar">
  <div class="sb-cell grow" id="sb-msg">Para obtener Ayuda, presione F1</div>
  <div class="sb-cell" id="sb-pos">X: 0   Y: 0</div>
  <div class="sb-cell" id="sb-size" style="display:none">W: 0   H: 0</div>
  <div class="sb-cell" id="sb-records">Registros: 9</div>
  <div class="sb-cell" id="sb-zoom">100%</div>
  <div class="sb-cell">ES</div>
  <div class="sb-cell" id="sb-time"></div>
</div>

</div><!-- /app -->

<!-- Helper overlays -->
<div id="field-drag-ghost"></div>
<div id="ctx-menu"></div>
<div id="selection-info"></div>
<div class="section-resize-badge" id="resize-badge"></div>

<!-- Hidden color pickers -->
<input type="color" id="color-picker-font"   style="position:fixed;opacity:0;pointer-events:none">
<input type="color" id="color-picker-bg"     style="position:fixed;opacity:0;pointer-events:none">
<input type="color" id="color-picker-border" style="position:fixed;opacity:0;pointer-events:none">
<script>
'use strict';
// ═══════════════════════════════════════════════════════════════════
//  CONFIG
// ═══════════════════════════════════════════════════════════════════
const CFG = {
  GRID: 4, PAGE_W: 754, // ~A4 minus margins (px at 96dpi)
  MIN_EL_W: 8, MIN_EL_H: 6,
  HANDLE_HIT: 4,
  SECTION_MIN_H: 12, SECTION_MAX_H: 800,
  ZOOM_LEVELS: [0.25,0.5,0.75,1.0,1.25,1.5,2.0,4.0],
  FONTS: ['Arial','Tahoma','Courier New','Times New Roman','Calibri','Verdana','Georgia'],
  FONT_SIZES: [6,7,8,9,10,11,12,14,16,18,20,24,28,36],
};

// ═══════════════════════════════════════════════════════════════════
//  FIELD TREE — maps build_invoice_model output
// ═══════════════════════════════════════════════════════════════════
