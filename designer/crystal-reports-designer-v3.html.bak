// ── Active state ──────────────────────────────────────────────────
DS._docType   = 'factura';
DS._sampleData = null; // set on DOMContentLoaded

// ── resolveField multi-doc aware ─────────────────────────────────
// Extend the existing resolveField to handle proveedor.* paths
const _origResolveField = resolveField;
window.resolveField = function(path, data, itemData) {
  if(!path) return '';
  if(path.startsWith('_special.')) return _origResolveField(path, data, itemData);
  if(itemData && path.startsWith('item.')) {
    const k = path.slice(5);
    return itemData[k] ?? '';
  }
  const keys = path.split('.');
  let v = data;
  for(const k of keys){ if(v==null)return''; v=v[k]; }
  return v ?? '';
};

// ── switchDocType ─────────────────────────────────────────────────
function switchDocType(key) {
  if(!(key in DOC_TYPES)) return;
  const dt = DOC_TYPES[key];
  const prev = DS._docType;
  DS._docType = key;

  // Buttons
  document.querySelectorAll('.doc-type-btn').forEach(btn =>
    btn.classList.toggle('active', btn.dataset.doctype === key));

  // Titlebar color
  const tb = document.getElementById('titlebar');
  if(tb) tb.style.background =
    `linear-gradient(180deg,${shadeColor(dt.color,20)} 0%,${dt.color} 60%,${shadeColor(dt.color,-10)} 100%)`;

  // Properties panel color
  const pt = document.getElementById('props-title');
  if(pt) pt.style.background =
    `linear-gradient(180deg,${shadeColor(dt.color,30)},${dt.color})`;

  // Field tree
  FieldExplorerEngine._activeTree = dt.fieldTree || FIELD_TREE;
  const oldRender = FieldExplorerEngine.render.bind(FieldExplorerEngine);
  FieldExplorerEngine.render = function(){
    const tree = this._activeTree || FIELD_TREE;
    const treeEl = document.getElementById('field-tree');
    treeEl.innerHTML = '';
    Object.entries(tree).forEach(([k,node]) => treeEl.appendChild(this._buildNode(k,node,0)));
  };
  FieldExplorerEngine.render();

  // Sample data
  DS._sampleData = dt.sampleData || SAMPLE_DATA;

  // Reset canvas if switching type
  if(prev !== key) {
    if(DS.elements.length > 0 &&
       !confirm(`¿Cambiar a "${dt.label}"?\nSe cargará el layout de secciones para este tipo.\n(Los elementos del canvas se borrarán)`))
    { // Revert
      DS._docType = prev;
      document.querySelectorAll('.doc-type-btn').forEach(btn =>
        btn.classList.toggle('active', btn.dataset.doctype === prev));
      return;
    }
    DS.sections = dt.defaultSections.map(s=>({...s}));
    DS.elements = [];
    DS.selection.clear();
    SectionEngine.render();
    CanvasEngine.renderAll();
    SelectionEngine.clearSelection();
    DS.saveHistory();
  }

  // Titlebar text
  const tt = document.getElementById('titlebar-text');
  if(tt) tt.textContent =
    `SAP Crystal Reports — [${dt.label} — Nuevo reporte (SRI ${dt.sriCode})]`;

  // Status bar
  const items = DS._sampleData?.items || [];
  document.getElementById('sb-msg').textContent =
    `Tipo "${dt.label}" activado — SRI ${dt.sriCode} — Arrastra campos del Explorador al canvas`;
  document.getElementById('sb-records').textContent = `Items: ${items.length}`;

  console.log(`[ReportForge] Doc type → ${key} (${dt.label}) SRI:${dt.sriCode}`);
}

function shadeColor(hex, pct) {
  // Lighten/darken a hex color
  const n = parseInt(hex.slice(1), 16);
  const r = Math.min(255, Math.max(0, (n>>16) + pct*2));
  const g = Math.min(255, Math.max(0, ((n>>8)&0xff) + pct*2));
  const b = Math.min(255, Math.max(0, (n&0xff) + pct*2));
  return `#${((r<<16)|(g<<8)|b).toString(16).padStart(6,'0')}`;
}

// ── Patch PreviewEngine to use active sample data ─────────────────
const _origPreviewShow = PreviewEngine.show.bind(PreviewEngine);
PreviewEngine.show = function() {
  const layer   = document.getElementById('preview-layer');
  const content = document.getElementById('preview-content');
  layer.classList.add('visible');
  document.getElementById('tab-preview').classList.add('active');
  document.getElementById('tab-design').classList.remove('active');
  DS.previewMode = true;
  const data = DS._sampleData || SAMPLE_DATA;
  content.innerHTML = this._renderWithData(data);
};

PreviewEngine._renderWithData = function(data) {
  let html = `<style>${this._buildCSS()}</style>`;
  const items = data.items || [];
  for(const sec of DS.sections) {
    if(sec.iterates) {
      items.forEach((item,i) => { html += this._renderSectionData(sec, item, i%2===1, data); });
    } else {
      html += this._renderSectionData(sec, null, false, data);
    }
  }
  return html;
};

PreviewEngine._renderSectionData = function(sec, itemData, altRow, rootData) {
  const els = DS.elements.filter(e => e.sectionId === sec.id);
  let inner = els.map(el => this._renderElementData(el, itemData, rootData)).join('');
  const bg = altRow ? 'background:#FAFAF8' : '';
  return `<div class="pv-section" style="position:relative;height:${sec.height}px;width:${CFG.PAGE_W}px;${bg};border-bottom:1px solid #EEE;overflow:hidden">${inner}</div>`;
};

PreviewEngine._renderElementData = function(el, itemData, rootData) {
  const data = rootData || DS._sampleData || SAMPLE_DATA;
  let value = '';
  if(el.type === 'field' && el.fieldPath) {
    const raw = resolveField(el.fieldPath, data, itemData);
    value = formatValue(raw, el.fieldFmt);
  } else {
    value = el.content || '';
  }
  const st = [
    `position:absolute`,`left:${el.x}px`,`top:${el.y}px`,
    `width:${el.w}px`,`height:${el.h}px`,
    `font-family:${el.fontFamily}`,`font-size:${el.fontSize}pt`,
    `font-weight:${el.bold?'bold':'normal'}`,
    `font-style:${el.italic?'italic':'normal'}`,
    `text-decoration:${el.underline?'underline':'none'}`,
    `text-align:${el.align}`,`color:${el.color}`,
    `overflow:hidden`,`display:flex`,`align-items:center`,
  ].join(';');
  if(el.type==='line'){
    const lc=el.borderColor==='transparent'?'#000':el.borderColor;
    const mid=Math.max(el.h/2,1);
    return `<div style="${st};background:transparent"><svg style="overflow:visible" width="${el.w}" height="${Math.max(el.h,2)}"><line x1="0" y1="${mid}" x2="${el.w}" y2="${mid}" stroke="${lc}" stroke-width="${el.lineWidth||1}"/></svg></div>`;
  }
  if(el.type==='rect'){
    const bg=el.bgColor==='transparent'?'transparent':el.bgColor;
    const brd=el.borderWidth>0?`border:${el.borderWidth}px ${el.borderStyle} ${el.borderColor}`:'';
    return `<div style="${st};background:${bg};${brd}"></div>`;
  }
  const bg=el.bgColor==='transparent'?'transparent':el.bgColor;
  const brd=el.borderWidth>0?`;border:${el.borderWidth}px ${el.borderStyle} ${el.borderColor}`:'';
  const esc=String(value).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  return `<div style="${st};background:${bg}${brd};padding:0 2px"><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">${esc}</span></div>`;
};

// ── Wire buttons on boot ──────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.doc-type-btn').forEach(btn =>
    btn.addEventListener('click', () => switchDocType(btn.dataset.doctype)));
  DS._sampleData = SAMPLE_DATA;
  const items = SAMPLE_DATA.items||[];
  document.getElementById('sb-records').textContent = `Items: ${items.length}`;
  console.log('[ReportForge] Multi-doc engine listo — 5 tipos: factura, remision, nota_credito, retencion, liquidacion');
});
</script>
</body>
</html>
