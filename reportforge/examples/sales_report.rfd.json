{
  "name": "Sales Report by Category",
  "version": "1.0",
  "pageSize": "A4",
  "orientation": "portrait",
  "pageWidth": 754,
  "margins": {
    "top": 15,
    "bottom": 15,
    "left": 20,
    "right": 20
  },
  "groups": [
    {
      "field": "category",
      "sortDesc": false,
      "label": "Category"
    }
  ],
  "sortBy": [
    {
      "field": "category",
      "desc": false
    },
    {
      "field": "total",
      "desc": true
    }
  ],
  "sections": [
    {
      "id": "s-rh",
      "stype": "rh",
      "label": "Report Header",
      "height": 72
    },
    {
      "id": "s-ph",
      "stype": "ph",
      "label": "Page Header",
      "height": 56
    },
    {
      "id": "s-gh",
      "stype": "gh",
      "label": "Group Header",
      "height": 22,
      "groupIndex": 0
    },
    {
      "id": "s-dt",
      "stype": "det",
      "label": "Detail",
      "height": 16,
      "iterates": "items"
    },
    {
      "id": "s-gf",
      "stype": "gf",
      "label": "Group Footer",
      "height": 22,
      "groupIndex": 0
    },
    {
      "id": "s-pf",
      "stype": "pf",
      "label": "Page Footer",
      "height": 36
    },
    {
      "id": "s-rf",
      "stype": "rf",
      "label": "Report Footer",
      "height": 52
    }
  ],
  "elements": [
    {
      "id": "rh-bg",
      "type": "rect",
      "sectionId": "s-rh",
      "x": 0,
      "y": 0,
      "w": 754,
      "h": 72,
      "bgColor": "#1A3A6B",
      "zIndex": 0
    },
    {
      "id": "rh-title",
      "type": "field",
      "sectionId": "s-rh",
      "x": 20,
      "y": 10,
      "w": 500,
      "h": 28,
      "fieldPath": "company.name",
      "fontSize": 16,
      "bold": true,
      "color": "#FFFFFF",
      "zIndex": 1
    },
    {
      "id": "rh-sub",
      "type": "text",
      "sectionId": "s-rh",
      "x": 20,
      "y": 42,
      "w": 400,
      "h": 16,
      "content": "Sales Report — {period}",
      "fontSize": 9,
      "color": "#B0C4DE",
      "zIndex": 1
    },
    {
      "id": "rh-date",
      "type": "text",
      "sectionId": "s-rh",
      "x": 580,
      "y": 10,
      "w": 160,
      "h": 14,
      "content": "Date: {report_date}",
      "fontSize": 8,
      "color": "#B0C4DE",
      "align": "right",
      "zIndex": 1
    },
    {
      "id": "rh-client",
      "type": "text",
      "sectionId": "s-rh",
      "x": 580,
      "y": 28,
      "w": 160,
      "h": 14,
      "content": "Client: {client.name}",
      "fontSize": 7,
      "color": "#B0C4DE",
