{
  "name": "Enterprise Sales Report",
  "pageSize": "A4",
  "pageWidth": 794,
  "pageHeight": 1123,
  "orientation": "portrait",
  "margins": {"top": 15, "bottom": 15, "left": 20, "right": 20},
  "groups": [{"field": "category", "sortDesc": false}],
  "sortBy": [{"field": "category", "desc": false}, {"field": "total", "desc": true}],
  "styles": {
    "company_name": {"fontSize": 14, "bold": true, "color": "#1A1A2E"},
    "section_title": {"fontSize": 10, "bold": true, "color": "#16213E", "bgColor": "#E8EAED"}
  },
  "sections": [
    {"id": "s-rh", "stype": "rh", "label": "Report Header", "height": 80},
    {"id": "s-ph", "stype": "ph", "label": "Page Header",   "height": 50},
    {"id": "s-gh", "stype": "gh", "label": "Group Header",  "height": 20, "visibleIf": "count(items) > 0"},
    {"id": "s-det","stype": "det","label": "Detail",        "height": 16, "iterates": "items"},
    {"id": "s-gf", "stype": "gf", "label": "Group Footer",  "height": 20},
    {"id": "s-rf", "stype": "rf", "label": "Report Footer", "height": 50, "pageBreakBefore": false},
    {"id": "s-pf", "stype": "pf", "label": "Page Footer",   "height": 25}
  ],
  "elements": [
    {"id":"rh-logo","type":"rect","sectionId":"s-rh","x":0,"y":0,"w":30,"h":80,
     "bgColor":"#1A1A2E","borderWidth":0,"zIndex":0},
    {"id":"rh-company","type":"text","sectionId":"s-rh","x":36,"y":8,"w":400,"h":20,
     "content":"{company.name}","fontSize":14,"bold":true,"color":"#1A1A2E"},
    {"id":"rh-subtitle","type":"text","sectionId":"s-rh","x":36,"y":30,"w":400,"h":14,
     "content":"Sales Performance Report","fontSize":10,"italic":true,"color":"#666666"},
    {"id":"rh-period","type":"text","sectionId":"s-rh","x":36,"y":48,"w":300,"h":12,
     "content":"Period: {param.startDate} – {param.endDate}","fontSize":8,"color":"#333333"},
    {"id":"rh-date","type":"text","sectionId":"s-rh","x":550,"y":8,"w":200,"h":12,
     "content":"Generated: {now()}","fontSize":7,"color":"#888888","align":"right"},
    {"id":"rh-rid","type":"text","sectionId":"s-rh","x":550,"y":22,"w":200,"h":12,
     "content":"Report ID: {uuid()}","fontSize":7,"color":"#888888","align":"right"},
    {"id":"rh-line","type":"line","sectionId":"s-rh","x":0,"y":72,"w":754,"h":2,
     "borderColor":"#1A1A2E","lineWidth":2},

    {"id":"ph-col1","type":"text","sectionId":"s-ph","x":4,"y":4,"w":100,"h":14,
     "content":"CODE","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"center"},
    {"id":"ph-col2","type":"text","sectionId":"s-ph","x":108,"y":4,"w":180,"h":14,
     "content":"PRODUCT","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E"},
    {"id":"ph-col3","type":"text","sectionId":"s-ph","x":292,"y":4,"w":55,"h":14,
     "content":"QTY","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"right"},
    {"id":"ph-col4","type":"text","sectionId":"s-ph","x":351,"y":4,"w":80,"h":14,
     "content":"UNIT PRICE","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"right"},
    {"id":"ph-col5","type":"text","sectionId":"s-ph","x":435,"y":4,"w":80,"h":14,
     "content":"DISCOUNT","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"right"},
    {"id":"ph-col6","type":"text","sectionId":"s-ph","x":519,"y":4,"w":90,"h":14,
     "content":"TOTAL","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"right"},
    {"id":"ph-col7","type":"text","sectionId":"s-ph","x":613,"y":4,"w":70,"h":14,
     "content":"STATUS","fontSize":7,"bold":true,"color":"#FFFFFF","bgColor":"#1A1A2E","align":"center"},
    {"id":"ph-line","type":"line","sectionId":"s-ph","x":4,"y":28,"w":750,"h":1,
     "borderColor":"#CCCCCC","lineWidth":1},
    {"id":"ph-client","type":"text","sectionId":"s-ph","x":4,"y":32,"w":400,"h":12,
     "content":"Client: {client.name}  |  RUC: {client.ruc}","fontSize":7,"color":"#666666"},

    {"id":"gh-cat","type":"text","sectionId":"s-gh","x":4,"y":3,"w":400,"h":14,
     "content":"▶ Category: {item.category}","fontSize":9,"bold":true,"color":"#1A1A2E"},
    {"id":"gh-cnt","type":"text","sectionId":"s-gh","x":500,"y":3,"w":150,"h":14,
     "content":"{count(items)} items in group","fontSize":7,"color":"#666666","align":"right"},

    {"id":"dt-code","type":"field","sectionId":"s-det","x":4,"y":1,"w":100,"h":14,
     "fieldPath":"item.code","fontSize":8,"align":"center",
     "conditionalStyles":[{"condition":"item.stock < 5","style":{"color":"#C62828","bold":true}}]},
    {"id":"dt-name","type":"field","sectionId":"s-det","x":108,"y":1,"w":180,"h":14,
     "fieldPath":"item.name","fontSize":8,"wordWrap":false},
    {"id":"dt-qty","type":"field","sectionId":"s-det","x":292,"y":1,"w":55,"h":14,
     "fieldPath":"item.qty","fieldFmt":"int","fontSize":8,"align":"right"},
    {"id":"dt-price","type":"field","sectionId":"s-det","x":351,"y":1,"w":80,"h":14,
     "fieldPath":"item.unit_price","fieldFmt":"currency","fontSize":8,"align":"right"},
    {"id":"dt-disc","type":"field","sectionId":"s-det","x":435,"y":1,"w":80,"h":14,
     "fieldPath":"item.discount","fieldFmt":"pct2","fontSize":8,"align":"right"},
    {"id":"dt-total","type":"field","sectionId":"s-det","x":519,"y":1,"w":90,"h":14,
     "fieldPath":"item.qty * item.unit_price * (1 - item.discount)","fieldFmt":"currency",
     "fontSize":8,"align":"right","bold":true},
    {"id":"dt-status","type":"field","sectionId":"s-det","x":613,"y":1,"w":70,"h":14,
     "fieldPath":"if item.stock < 5 then 'LOW STOCK' else if item.stock < 20 then 'OK' else 'IN STOCK'",
     "fontSize":7,"align":"center",
     "conditionalStyles":[
       {"condition":"item.stock < 5","style":{"bgColor":"#FFEBEE","color":"#C62828","bold":true}},
       {"condition":"item.stock >= 20","style":{"bgColor":"#E8F5E9","color":"#2E7D32"}}
     ]},
    {"id":"dt-running","type":"field","sectionId":"s-det","x":4,"y":1,"w":90,"h":14,
     "fieldPath":"runningSum(items.total)","fieldFmt":"currency",
     "fontSize":7,"color":"#999999","align":"right","suppressIfEmpty":true},

    {"id":"gf-label","type":"text","sectionId":"s-gf","x":4,"y":3,"w":300,"h":14,
     "content":"Subtotal {item.category}:","fontSize":8,"bold":true,"color":"#333333"},
    {"id":"gf-total","type":"field","sectionId":"s-gf","x":519,"y":3,"w":90,"h":14,
     "fieldPath":"sum(items.total)","fieldFmt":"currency",
     "fontSize":9,"bold":true,"align":"right","color":"#1A1A2E"},
    {"id":"gf-line","type":"line","sectionId":"s-gf","x":4,"y":0,"w":750,"h":1,
     "borderColor":"#CCCCCC","lineWidth":1},

    {"id":"rf-line","type":"line","sectionId":"s-rf","x":4,"y":0,"w":750,"h":2,
     "borderColor":"#1A1A2E","lineWidth":2},
    {"id":"rf-lbl-total","type":"text","sectionId":"s-rf","x":4,"y":8,"w":400,"h":16,
     "content":"GRAND TOTAL","fontSize":11,"bold":true,"color":"#1A1A2E"},
    {"id":"rf-grand-total","type":"field","sectionId":"s-rf","x":519,"y":8,"w":90,"h":16,
     "fieldPath":"sum(items.total)","fieldFmt":"currency_sign",
     "fontSize":11,"bold":true,"align":"right","color":"#1A1A2E"},
    {"id":"rf-count","type":"text","sectionId":"s-rf","x":4,"y":28,"w":400,"h":12,
     "content":"{count(items)} items  |  Avg: {avg(items.total):.2f}","fontSize":8,"color":"#666666"},
    {"id":"rf-env","type":"text","sectionId":"s-rf","x":550,"y":28,"w":200,"h":12,
     "content":"Prepared by: {env.USER}","fontSize":7,"color":"#999999","align":"right"},

    {"id":"pf-brand","type":"text","sectionId":"s-pf","x":4,"y":6,"w":300,"h":12,
     "content":"ReportForge Enterprise — {company.name}","fontSize":7,"color":"#888888"},
    {"id":"pf-conf","type":"text","sectionId":"s-pf","x":350,"y":6,"w":400,"h":12,
     "content":"CONFIDENTIAL — {param.startDate} to {param.endDate}","fontSize":7,"color":"#C62828","align":"right"}
  ]
}
