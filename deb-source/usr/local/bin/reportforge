#!/bin/bash
# ReportForge launcher
# Starts the Python server and opens the designer in the browser

set -e

APP_DIR="/opt/reportforge"
PYTHON="python3"

# Verify Python 3 is available
if ! command -v python3 &>/dev/null; then
    zenity --error --text="ReportForge necesita Python 3.\nInstálalo con: sudo apt install python3" 2>/dev/null ||
    echo "ERROR: Python 3 no encontrado. Instala con: sudo apt install python3" >&2
    exit 1
fi

# Launch server
exec "$PYTHON" "$APP_DIR/server.py" "$@"
